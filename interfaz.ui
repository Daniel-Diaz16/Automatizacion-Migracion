<?xml version="1.0" encoding="UTF-8"?>
<ui version="4.0">
 <class>MainWindow</class>
 <widget class="QMainWindow" name="MainWindow">
  <property name="geometry">
   <rect>
    <x>0</x>
    <y>0</y>
    <width>780</width>
    <height>620</height>
   </rect>
  </property>
  <property name="windowTitle">
   <string>Sistema de Automatización de Migraciones VTR</string>
  </property>
  <property name="styleSheet">
   <string notr="true">
    QMainWindow {
        background-color: #f0f2f5;
    }
    QLabel#lbl_title {
        color: #1a365d;
        font-size: 16px;
        font-weight: bold;
        padding: 5px;
        font-family: 'Segoe UI', Arial, sans-serif;
    }
    QLabel#lbl_zona, QLabel#lbl_estado {
        color: #4a5568;
        font-size: 10px;
        font-family: 'Segoe UI', Arial, sans-serif;
    }
    QPushButton {
        background-color: #ffffff;
        border: 1px solid #cbd5e0;
        border-radius: 5px;
        color: #2d3748;
        font-size: 11px;
        font-weight: 500;
        padding: 6px 12px;
        min-height: 30px;
        font-family: 'Segoe UI', Arial, sans-serif;
    }
    QPushButton:hover {
        background-color: #edf2f7;
        border-color: #a0aec0;
    }
    QPushButton:pressed {
        background-color: #e2e8f0;
    }
    QPushButton#btn_iniciar_reloj {
        background-color: #2c7a7b;
        border-color: #2c7a7b;
        color: #ffffff;
    }
    QPushButton#btn_iniciar_reloj:hover {
        background-color: #285e61;
        border-color: #285e61;
    }
    QPushButton#btn_detener_programador {
        background-color: #e53e3e;
        border-color: #e53e3e;
        color: #ffffff;
    }
    QPushButton#btn_detener_programador:hover {
        background-color: #c53030;
        border-color: #c53030;
    }
    QPushButton#btn_ejecutar_manual {
        background-color: #3182ce;
        border-color: #3182ce;
        color: #ffffff;
    }
    QPushButton#btn_ejecutar_manual:hover {
        background-color: #2c5282;
        border-color: #2c5282;
    }
    QPushButton#btn_limpiar_consola {
        background-color: #718096;
        border-color: #718096;
        color: #ffffff;
    }
    QPushButton#btn_limpiar_consola:hover {
        background-color: #4a5568;
        border-color: #4a5568;
    }
    QPushButton#btn_guardar_rutas {
        background-color: #38a169;
        border-color: #38a169;
        color: #ffffff;
    }
    QPushButton#btn_guardar_rutas:hover {
        background-color: #2f855a;
        border-color: #2f855a;
    }
    QPushButton#btn_restaurar_rutas {
        background-color: #d69e2e;
        border-color: #d69e2e;
        color: #ffffff;
    }
    QPushButton#btn_restaurar_rutas:hover {
        background-color: #b7791f;
        border-color: #b7791f;
    }
    QPushButton#btn_guardar_codigo {
        background-color: #38a169;
        border-color: #38a169;
        color: #ffffff;
    }
    QPushButton#btn_guardar_codigo:hover {
        background-color: #2f855a;
        border-color: #2f855a;
    }
    QPushButton#btn_cargar_codigo {
        background-color: #3182ce;
        border-color: #3182ce;
        color: #ffffff;
    }
    QPushButton#btn_cargar_codigo:hover {
        background-color: #2c5282;
        border-color: #2c5282;
    }
    QPushButton#btn_explorar_ruta {
        background-color: #805ad5;
        border-color: #805ad5;
        color: #ffffff;
        font-size: 14px;
        padding: 0px 10px;
        min-width: 35px;
        min-height: 30px;
    }
    QPushButton#btn_explorar_ruta:hover {
        background-color: #6b46c1;
        border-color: #6b46c1;
    }
    QGroupBox {
        color: #2d3748;
        font-weight: 600;
        border: 1px solid #e2e8f0;
        border-radius: 6px;
        margin-top: 8px;
        padding-top: 8px;
        background-color: #ffffff;
    }
    QGroupBox::title {
        subcontrol-origin: margin;
        left: 10px;
        padding: 0 8px 0 8px;
        color: #1a365d;
    }
    QTextEdit {
        background-color: #1a202c;
        color: #a0f0e8;
        border: 1px solid #2d3748;
        border-radius: 5px;
        font-family: 'Consolas', 'Monaco', monospace;
        font-size: 9px;
        selection-background-color: #3182ce;
    }
    QTableWidget {
        background-color: #ffffff;
        color: #2d3748;
        border: 1px solid #e2e8f0;
        border-radius: 5px;
        gridline-color: #edf2f7;
        font-family: 'Segoe UI', Arial, sans-serif;
        font-size: 10px;
    }
    QTableWidget::item:selected {
        background-color: #bee3f8;
        color: #1a365d;
    }
    QHeaderView::section {
        background-color: #f7fafc;
        color: #2d3748;
        font-weight: 600;
        padding: 5px;
        border: none;
        border-bottom: 2px solid #e2e8f0;
        font-family: 'Segoe UI', Arial, sans-serif;
        font-size: 10px;
    }
    QProgressBar {
        border: 1px solid #e2e8f0;
        border-radius: 3px;
        text-align: center;
        color: #2d3748;
        background-color: #edf2f7;
        height: 5px;
    }
    QProgressBar::chunk {
        background-color: #3182ce;
        border-radius: 2px;
    }
    QTabWidget::pane {
        border: 1px solid #e2e8f0;
        border-radius: 6px;
        background-color: #ffffff;
        top: -1px;
    }
    QTabBar::tab {
        background-color: #edf2f7;
        color: #4a5568;
        padding: 8px 15px;
        margin-right: 3px;
        border-top-left-radius: 5px;
        border-top-right-radius: 5px;
        font-family: 'Segoe UI', Arial, sans-serif;
        font-size: 10px;
        font-weight: 500;
    }
    QTabBar::tab:selected {
        background-color: #ffffff;
        color: #3182ce;
        border-bottom: 2px solid #3182ce;
    }
    QTabBar::tab:hover:!selected {
        background-color: #e2e8f0;
        color: #2d3748;
    }
    QScrollBar:vertical {
        background-color: #f7fafc;
        width: 8px;
        border-radius: 4px;
    }
    QScrollBar::handle:vertical {
        background-color: #cbd5e0;
        border-radius: 4px;
        min-height: 15px;
    }
    QScrollBar::handle:vertical:hover {
        background-color: #a0aec0;
    }
    QScrollBar::add-line:vertical, QScrollBar::sub-line:vertical {
        height: 0px;
    }
    QScrollBar:horizontal {
        background-color: #f7fafc;
        height: 8px;
        border-radius: 4px;
    }
    QScrollBar::handle:horizontal {
        background-color: #cbd5e0;
        border-radius: 4px;
        min-width: 15px;
    }
    QScrollBar::handle:horizontal:hover {
        background-color: #a0aec0;
    }
    QLineEdit {
        background-color: #ffffff;
        border: 1px solid #e2e8f0;
        border-radius: 4px;
        padding: 5px;
        font-family: 'Segoe UI', Arial, sans-serif;
        font-size: 10px;
        color: #2d3748;
    }
    QLineEdit:focus {
        border-color: #3182ce;
        outline: none;
    }
    QComboBox {
        background-color: #ffffff;
        border: 1px solid #e2e8f0;
        border-radius: 4px;
        padding: 5px;
        font-family: 'Segoe UI', Arial, sans-serif;
        font-size: 10px;
        color: #2d3748;
        min-height: 28px;
    }
    QComboBox:focus {
        border-color: #3182ce;
    }
    QComboBox::drop-down {
        border: none;
    }
    QComboBox::down-arrow {
        image: none;
        border-left: 4px solid transparent;
        border-right: 4px solid transparent;
        border-top: 4px solid #4a5568;
        margin-right: 6px;
    }
   </string>
  </property>
