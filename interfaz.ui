  <property name="styleSheet">
   <string notr="true">
    QMainWindow {
        background-color: #f0f2f5;
    }
    QLabel#lbl_title {
        color: #1a365d;
        font-size: 18px;
        font-weight: bold;
        padding: 10px;
        font-family: 'Segoe UI', Arial, sans-serif;
    }
    QLabel#lbl_zona, QLabel#lbl_estado {
        color: #4a5568;
        font-size: 11px;
        font-family: 'Segoe UI', Arial, sans-serif;
    }
    QPushButton {
        background-color: #ffffff;
        border: 1px solid #cbd5e0;
        border-radius: 6px;
        color: #2d3748;
        font-size: 12px;
        font-weight: 500;
        padding: 8px 15px;
        min-height: 35px;
        font-family: 'Segoe UI', Arial, sans-serif;
    }
    QPushButton:hover {
        background-color: #edf2f7;
        border-color: #a0aec0;
    }
    QPushButton:pressed {
        background-color: #e2e8f0;
    }
    QPushButton#btn_iniciar_reloj {
        background-color: #2c7a7b;
        border-color: #2c7a7b;
        color: #ffffff;
    }
    QPushButton#btn_iniciar_reloj:hover {
        background-color: #285e61;
        border-color: #285e61;
    }
    QPushButton#btn_detener_programador {
        background-color: #e53e3e;
        border-color: #e53e3e;
        color: #ffffff;
    }
    QPushButton#btn_detener_programador:hover {
        background-color: #c53030;
        border-color: #c53030;
    }
    QPushButton#btn_ejecutar_manual {
        background-color: #3182ce;
        border-color: #3182ce;
        color: #ffffff;
    }
    QPushButton#btn_ejecutar_manual:hover {
        background-color: #2c5282;
        border-color: #2c5282;
    }
    QPushButton#btn_limpiar_consola {
        background-color: #718096;
        border-color: #718096;
        color: #ffffff;
    }
    QPushButton#btn_limpiar_consola:hover {
        background-color: #4a5568;
        border-color: #4a5568;
    }
    QPushButton#btn_guardar_rutas {
        background-color: #38a169;
        border-color: #38a169;
        color: #ffffff;
    }
    QPushButton#btn_guardar_rutas:hover {
        background-color: #2f855a;
        border-color: #2f855a;
    }
    QPushButton#btn_restaurar_rutas {
        background-color: #d69e2e;
        border-color: #d69e2e;
        color: #ffffff;
    }
    QPushButton#btn_restaurar_rutas:hover {
        background-color: #b7791f;
        border-color: #b7791f;
    }
    QPushButton#btn_guardar_codigo {
        background-color: #38a169;
        border-color: #38a169;
        color: #ffffff;
    }
    QPushButton#btn_guardar_codigo:hover {
        background-color: #2f855a;
        border-color: #2f855a;
    }
    QPushButton#btn_cargar_codigo {
        background-color: #3182ce;
        border-color: #3182ce;
        color: #ffffff;
    }
    QPushButton#btn_cargar_codigo:hover {
        background-color: #2c5282;
        border-color: #2c5282;
    }
    QPushButton#btn_agregar_horario {
        background-color: #38a169;
        border-color: #38a169;
        color: #ffffff;
    }
    QPushButton#btn_agregar_horario:hover {
        background-color: #2f855a;
        border-color: #2f855a;
    }
    QPushButton#btn_modificar_horario {
        background-color: #d69e2e;
